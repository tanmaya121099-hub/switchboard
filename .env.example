# ── TTS providers (benchmark + agent) ─────────────────────────────
# You only need keys for the providers you want to benchmark; the harness
# skips providers with no key. All four have free/cheap starter tiers.

# https://play.cartesia.ai → API Keys
CARTESIA_API_KEY=
# Pick a voice at https://play.cartesia.ai (defaults to a public sample voice)
CARTESIA_VOICE_ID=
CARTESIA_MODEL=sonic-3
# API version header — check https://docs.cartesia.ai if requests 400
CARTESIA_VERSION=2025-04-16

# https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_flash_v2_5

# https://platform.openai.com (also used for the agent LLM if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# https://console.deepgram.com (also used for agent STT)
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ── Benchmark metadata ─────────────────────────────────────────────
# Recorded in results so your published numbers state where they were measured from.
BENCH_REGION=Bengaluru, India (home fiber)

# ── Agent: LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-sonnet-4-6     # or gpt-4o-mini with LLM_PROVIDER=openai

# ── Agent: STT language ────────────────────────────────────────────
# "multi" enables Deepgram nova-3 code-switching (Hinglish). Use "en" or "hi" to pin.
DEEPGRAM_STT_LANGUAGE=multi
DEEPGRAM_STT_MODEL=nova-3

# ── Agent: telephony ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Public hostname Twilio can reach (your ngrok domain, no scheme), e.g. abc123.ngrok.app
PUBLIC_HOST=

# ── Agent: behavior ────────────────────────────────────────────────
PLAYBOOK=cod_confirmation       # cod_confirmation | refund_status

# ── Public-demo guards (bound what a stranger can cost you) ────────
MAX_CALLS_PER_DAY=50
MAX_CALL_SECONDS=180
